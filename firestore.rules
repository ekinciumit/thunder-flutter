rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPERS
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function chatIdContainsUser(chatId) {
      return chatId.matches('.*' + request.auth.uid + '.*');
    }

    function uidAddedToList(field) {
      let before = resource.data.get(field, []);
      let after = request.resource.data.get(field, []);
      return after.size() == before.size() + 1
        && after.hasAll(before)
        && after.hasAny([request.auth.uid]);
    }

    function uidRemovedFromList(field) {
      let before = resource.data.get(field, []);
      let after = request.resource.data.get(field, []);
      return before.size() == after.size() + 1
        && before.hasAll(after)
        && before.hasAny([request.auth.uid]);
    }

    function uidToggledInList(field) {
      return uidAddedToList(field) || uidRemovedFromList(field);
    }

    function isChatParticipant(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function canAccessChat(chatId) {
      return isChatParticipant(chatId) || chatIdContainsUser(chatId);
    }

    function isChatParticipantFromResource() {
      return resource.data.participants != null
        && request.auth.uid in resource.data.participants;
    }

    function canAccessChatFromResource() {
      return isChatParticipantFromResource() || chatIdContainsUser(resource.id);
    }

    function isChatAdmin() {
      return resource.data.get('createdBy', '') == request.auth.uid
        || (resource.data.get('admins', []) is list
            && request.auth.uid in resource.data.admins);
    }

    function ownUserUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['displayName'])
        || keys.hasOnly(['username'])
        || keys.hasOnly(['bio'])
        || keys.hasOnly(['photoUrl'])
        || keys.hasOnly(['email'])
        || keys.hasOnly(['isPrivate'])
        || keys.hasOnly(['showLocation'])
        || keys.hasOnly(['showOnlineStatus'])
        || keys.hasOnly(['fcmTokens'])
        || keys.hasOnly(['blockedUsers'])
        || keys.hasOnly(['sentFollowRequests'])
        || keys.hasOnly(['following'])
        || keys.hasOnly(['pendingFollowRequests'])
        || keys.hasOnly(['followers', 'pendingFollowRequests'])
        || keys.hasOnly(['following', 'sentFollowRequests', 'blockedUsers'])
        || keys.hasOnly(['followers', 'following', 'sentFollowRequests'])
        || keys.hasOnly([
          'displayName', 'username', 'bio', 'photoUrl', 'email',
          'isPrivate', 'showLocation', 'showOnlineStatus',
        ])
        || keys.hasOnly([
          'displayName', 'username', 'bio', 'photoUrl', 'email',
          'isPrivate', 'showLocation', 'showOnlineStatus', 'fcmTokens',
          'followers', 'following', 'pendingFollowRequests', 'sentFollowRequests', 'blockedUsers',
        ]);
    }

    function otherUserSocialUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return (keys.hasOnly(['pendingFollowRequests']) && uidToggledInList('pendingFollowRequests'))
        || (keys.hasOnly(['followers']) && uidToggledInList('followers'))
        || (keys.hasOnly(['following']) && uidToggledInList('following'))
        || (keys.hasOnly(['following', 'sentFollowRequests'])
            && uidAddedToList('following')
            && uidRemovedFromList('sentFollowRequests'))
        || keys.hasOnly(['followers', 'following', 'sentFollowRequests']);
    }

    function clientNotificationTypeAllowed() {
      return request.resource.data.type in [
        'follow_request',
        'follow_request_accepted',
        'event_invitation',
        'event_join_request',
        'event_join_approved',
        'event_join_rejected',
        'event_cancelled',
        'event_updated',
        'event_reminder',
        'event_reminder_24h',
        'event_reminder_2h',
        'event_check_in',
        'new_followers',
        'message',
        'message_request',
        'weekly_digest',
      ];
    }

    function messageParticipantUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['status', 'readAt'])
        || keys.hasOnly(['reactions'])
        || keys.hasOnly(['isDeleted', 'deletedAt']);
    }

    function messageSenderUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['text', 'isEdited', 'editedAt'])
        || keys.hasOnly(['status'])
        || keys.hasOnly(['isDeleted', 'deletedAt'])
        || keys.hasOnly(['reactions']);
    }

    function chatMetaUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['lastMessage', 'lastMessageAt'])
        || keys.hasOnly(['typingStatus'])
        || keys.hasOnly(['mutedUntil'])
        || keys.hasOnly(['mutedBy'])
        || keys.hasOnly(['mutedUntil', 'mutedBy'])
        || keys.hasOnly(['participantDetails']);
    }

    function chatGroupInfoUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['name'])
        || keys.hasOnly(['description'])
        || keys.hasOnly(['photoUrl'])
        || keys.hasOnly(['name', 'description'])
        || keys.hasOnly(['name', 'photoUrl'])
        || keys.hasOnly(['description', 'photoUrl'])
        || keys.hasOnly(['name', 'description', 'photoUrl'])
        || keys.hasOnly(['admins']);
    }

    function chatParticipantsUpdateAllowed() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      let before = resource.data.get('participants', []);
      let after = request.resource.data.get('participants', []);
      let participantKeysOnly = keys.hasOnly(['participants'])
        || keys.hasOnly(['participants', 'participantDetails'])
        || keys.hasOnly(['participants', 'admins'])
        || keys.hasOnly(['participants', 'participantDetails', 'admins']);
      return participantKeysOnly && (
        (before.size() == after.size() + 1
          && before.hasAll(after)
          && before.hasAny([request.auth.uid])
          && !after.hasAny([request.auth.uid]))
        || (isChatAdmin() && after.size() == before.size() + 1 && after.hasAll(before))
        || (isChatAdmin() && before.size() == after.size() + 1 && before.hasAll(after))
      );
    }

    // =========================================================================
    // USERS
    // =========================================================================

    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;

      allow read: if isSignedIn();

      allow update: if isSignedIn() && (
        (isOwner(userId) && ownUserUpdateAllowed())
        || (!isOwner(userId) && otherUserSocialUpdateAllowed())
      );

      allow delete: if false;
    }

    // =========================================================================
    // EVENTS
    // =========================================================================

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid
        || (
          'pendingRequests' in request.resource.data.diff(resource.data).affectedKeys()
          && 'pendingRequests' in request.resource.data
          && (
            request.resource.data.pendingRequests.hasAny([request.auth.uid])
            != ('pendingRequests' in resource.data
                && resource.data.pendingRequests != null
                && resource.data.pendingRequests.hasAny([request.auth.uid]))
          )
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.datetime == resource.data.datetime
          && request.resource.data.title == resource.data.title
        )
        || (
          (
            (resource.data.participants != null && resource.data.participants.hasAny([request.auth.uid]))
            || (resource.data.approvedParticipants != null
                && resource.data.approvedParticipants.hasAny([request.auth.uid]))
          )
          && (request.resource.data.participants == null
              || !request.resource.data.participants.hasAny([request.auth.uid]))
          && (request.resource.data.approvedParticipants == null
              || !request.resource.data.approvedParticipants.hasAny([request.auth.uid]))
        )
      );

      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        function isEventParticipant() {
          return exists(/databases/$(database)/documents/events/$(eventId)) && (
            get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid
            || get(/databases/$(database)/documents/events/$(eventId)).data.approvedParticipants.hasAny([request.auth.uid])
            || get(/databases/$(database)/documents/events/$(eventId)).data.participants.hasAny([request.auth.uid])
          );
        }

        allow read: if isSignedIn() && isEventParticipant();

        allow create: if isSignedIn()
          && isEventParticipant()
          && request.resource.data.senderId == request.auth.uid;

        allow update: if isSignedIn()
          && resource.data.senderId == request.auth.uid;

        allow delete: if isSignedIn() && (
          resource.data.senderId == request.auth.uid
          || (
            exists(/databases/$(database)/documents/events/$(eventId))
            && get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid
          )
        );
      }

      match /comments/{commentId} {
        function isEventOwner() {
          return exists(/databases/$(database)/documents/events/$(eventId))
            && get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid;
        }

        function isEventParticipant() {
          return exists(/databases/$(database)/documents/events/$(eventId)) && (
            get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid
            || get(/databases/$(database)/documents/events/$(eventId)).data.approvedParticipants.hasAny([request.auth.uid])
            || get(/databases/$(database)/documents/events/$(eventId)).data.participants.hasAny([request.auth.uid])
          );
        }

        allow read: if isSignedIn() && isEventParticipant();

        allow create: if isSignedIn() && (
          (
            request.resource.data.type == 'system'
            && request.resource.data.userId == 'system'
            && isEventParticipant()
          )
          || (
            (!('type' in request.resource.data) || request.resource.data.type != 'system')
            && request.resource.data.userId == request.auth.uid
            && isEventParticipant()
          )
        );

        allow update, delete: if isSignedIn() && (
          (
            resource.data.userId == request.auth.uid
            && (!('type' in resource.data) || resource.data.type != 'system')
          )
          || (
            isEventOwner()
            && (!('type' in resource.data) || resource.data.type != 'system')
          )
        );
      }
    }

    // =========================================================================
    // CHATS
    // =========================================================================

    match /chats/{chatId} {
      allow read: if isSignedIn() && canAccessChatFromResource();

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && canAccessChatFromResource()
        && (
          chatMetaUpdateAllowed()
          || (isChatAdmin() && chatGroupInfoUpdateAllowed())
          || chatParticipantsUpdateAllowed()
        );

      allow delete: if isSignedIn()
        && resource.data.get('createdBy', '') == request.auth.uid;
    }

    // =========================================================================
    // MESSAGES (top-level)
    // =========================================================================

    match /messages/{messageId} {
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.chatId != null
        && canAccessChat(request.resource.data.chatId);

      allow read: if isSignedIn() && (
        canAccessChat(resource.data.chatId)
        || resource.data.senderId == request.auth.uid
      );

      allow update: if isSignedIn()
        && canAccessChat(resource.data.chatId)
        && (
          (resource.data.senderId == request.auth.uid && messageSenderUpdateAllowed())
          || messageParticipantUpdateAllowed()
        );

      allow delete: if isSignedIn()
        && resource.data.senderId == request.auth.uid;
    }

    // =========================================================================
    // NOTIFICATIONS
    // =========================================================================

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId != request.auth.uid
        && clientNotificationTypeAllowed()
        && request.resource.data.userId is string
        && request.resource.data.userId != '';

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }

    // =========================================================================
    // FEEDBACKS
    // =========================================================================

    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;

      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }
  }
}
